fn main() -> i32 {
	let count: i32 = std::process::args_len();

	if count == 1 {
		for let mut env_index: i32 = 0; env_index < std::env::len(); env_index++ {
			println(std::env::at(env_index));
		}
		return 0;
	}

	let mut rc: i32 = 0;
	for let mut arg_index: i32 = 1; arg_index < count; arg_index++ {
		let value: str = std::env::get(std::process::arg_at(arg_index));
		if str_is_empty(value) {
			rc = 1;
		} else {
			println(value);
		}
	}

	return rc;
}
